<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.PerfilPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5F7FA" Offset="0.0"/>
                    <GradientStop Color="#FFFFFF" Offset="0.45"/>
                    <GradientStop Color="#1F2F2F" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="15">

                <Image Source="logo_safebarrio.png"
                       HeightRequest="110"
                       HorizontalOptions="Center"/>

                <Border BackgroundColor="#F0FFFFFF" StrokeThickness="0" Padding="22">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">

                        <Label Text="Mi Perfil"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#1D3148"
                               HorizontalTextAlignment="Center"/>

                        <Label x:Name="NombreLabel"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1D3148"
                               HorizontalTextAlignment="Center"/>

                        <Label x:Name="CorreoLabel"
                               TextColor="Black"
                               HorizontalTextAlignment="Center"/>

                        <Border BackgroundColor="#EEF3F6" StrokeThickness="0" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">
                                <Label x:Name="TelefonoLabel" TextColor="Black"/>
                                <Label x:Name="UbicacionLabel" TextColor="Black"/>
                                <Label x:Name="RolLabel" TextColor="#82A914" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout x:Name="EditarLayout" Spacing="12" IsVisible="False">

                            <Entry x:Name="NombreEntry"
                                   Placeholder="Nombre"
                                   TextColor="Black"
                                   BackgroundColor="White"/>

                            <Entry x:Name="ApellidoEntry"
                                   Placeholder="Apellido"
                                   TextColor="Black"
                                   BackgroundColor="White"/>

                            <Entry x:Name="TelefonoEntry"
                                   Placeholder="Teléfono"
                                   Keyboard="Telephone"
                                   TextColor="Black"
                                   BackgroundColor="White"/>

                            <Entry x:Name="UbicacionEntry"
                                   Placeholder="Dirección / Ubicación"
                                   TextColor="Black"
                                   BackgroundColor="White"/>

                            <Button Text="Guardar Cambios"
                                    BackgroundColor="#82A914"
                                    TextColor="White"
                                    CornerRadius="24"
                                    Clicked="OnGuardarClicked"/>

                        </VerticalStackLayout>

                        <Button x:Name="EditarButton"
                                Text="Editar Perfil"
                                BackgroundColor="#D3B52C"
                                TextColor="Black"
                                CornerRadius="24"
                                Clicked="OnEditarClicked"/>

                        <Button Text="Volver"
                                BackgroundColor="#1D3148"
                                TextColor="White"
                                CornerRadius="24"
                                Clicked="OnVolverClicked"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>