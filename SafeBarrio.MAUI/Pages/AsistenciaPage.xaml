<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.AsistenciaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5F7FA" Offset="0.0"/>
                    <GradientStop Color="#FFFFFF" Offset="0.45"/>
                    <GradientStop Color="#1F2F2F" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <VerticalStackLayout Padding="25" Spacing="15">

            <Image Source="logo_safebarrio.png"
                   HeightRequest="100"
                   HorizontalOptions="Center"/>

            <Label Text="Asistencia Rápida"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1D3148"
                   HorizontalTextAlignment="Center"/>

            <Border BackgroundColor="#F0FFFFFF" StrokeThickness="0" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">

                    <ScrollView HeightRequest="380">
                        <VerticalStackLayout x:Name="ChatLayout" Spacing="10">
                            <Label Text="SafeBot: Hola, soy tu asistente de seguridad. Puedes preguntarme qué hacer ante una emergencia, robo o zona peligrosa."
                                   TextColor="Black"/>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Entry x:Name="MensajeEntry"
                           Placeholder="Escribe tu pregunta..."
                           TextColor="Black"
                           BackgroundColor="White"/>

                    <Button Text="Enviar"
                            BackgroundColor="#4A78AE"
                            TextColor="White"
                            CornerRadius="24"
                            Clicked="OnEnviarClicked"/>

                    <Button Text="Volver"
                            BackgroundColor="#82A914"
                            TextColor="White"
                            CornerRadius="24"
                            Clicked="OnVolverClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </Grid>
</ContentPage>