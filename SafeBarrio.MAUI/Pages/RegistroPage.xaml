<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.RegistroPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5F7FA" Offset="0.0"/>
                    <GradientStop Color="#FFFFFF" Offset="0.45"/>
                    <GradientStop Color="#1F2F2F" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="15" VerticalOptions="Center">

                <Border BackgroundColor="#F0FFFFFF" StrokeThickness="0" Padding="25">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">

                        <Image Source="logo_safebarrio.png"
                               HeightRequest="120"
                               HorizontalOptions="Center"/>

                        <Label Text="Crear Cuenta"
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#1D3148"/>

                        <Entry Placeholder="Nombre completo"/>
                        <Entry Placeholder="Correo electrónico" Keyboard="Email"/>
                        <Entry Placeholder="Teléfono" Keyboard="Telephone"/>
                        <Entry Placeholder="Dirección"/>
                        <Entry Placeholder="Contraseña" IsPassword="True"/>

                        <Button Text="Registrarse"
                                BackgroundColor="#82A914"
                                TextColor="White"
                                CornerRadius="24"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>