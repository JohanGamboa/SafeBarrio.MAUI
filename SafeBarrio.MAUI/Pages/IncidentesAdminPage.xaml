<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.IncidentesAdminPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Image Source="logo_safebarrio.png"
               HeightRequest="90"
               HorizontalOptions="Center"/>

        <Label Text="Todos los Incidentes"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#1D3148"
               HorizontalTextAlignment="Center"/>

        <CollectionView x:Name="IncidentesCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#F0FFFFFF" Padding="15" Margin="0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">

                            <Image Source="{Binding imagenRuta}"
                                   HeightRequest="130"
                                   Aspect="AspectFill"/>

                            <Label Text="{Binding tipoIncidente}" FontSize="20" FontAttributes="Bold" TextColor="#1D3148"/>
                            <Label Text="{Binding descripcion}" TextColor="Black"/>
                            <Label Text="{Binding direccionReferencia}" TextColor="Black"/>
                            <Label Text="{Binding estado}" TextColor="#82A914" FontAttributes="Bold"/>
                            <Label Text="{Binding fechaReporte}" TextColor="#666666" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Volver"
                BackgroundColor="#82A914"
                TextColor="White"
                CornerRadius="24"
                Clicked="OnVolverClicked"/>

    </VerticalStackLayout>
</ContentPage>