<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.AlertasSOSAdminPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Image Source="logo_safebarrio.png"
               HeightRequest="90"
               HorizontalOptions="Center"/>

        <Label Text="Todas las Alertas SOS"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#1D3148"
               HorizontalTextAlignment="Center"/>

        <CollectionView x:Name="AlertasCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#FFE5E5" Padding="15" Margin="0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding estado}" FontSize="20" FontAttributes="Bold" TextColor="#B00020"/>
                            <Label Text="{Binding mensaje}" TextColor="Black"/>
                            <Label Text="{Binding fechaAlerta}" TextColor="#666666" FontSize="13"/>
                            <Label Text="{Binding latitud, StringFormat='Lat: {0}'}" TextColor="Black"/>
                            <Label Text="{Binding longitud, StringFormat='Lng: {0}'}" TextColor="Black"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Volver"
                BackgroundColor="#82A914"
                TextColor="White"
                CornerRadius="24"
                Clicked="OnVolverClicked"/>

    </VerticalStackLayout>
</ContentPage>