<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.SOSPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5F7FA" Offset="0.0"/>
                    <GradientStop Color="#FFFFFF" Offset="0.45"/>
                    <GradientStop Color="#1F2F2F" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="18">

                <Image Source="logo_safebarrio.png"
                       HeightRequest="120"
                       HorizontalOptions="Center"/>

                <Border BackgroundColor="#F0FFFFFF" StrokeThickness="0" Padding="22">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="18">

                        <Label Text="🚨 EMERGENCIA SOS"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#E64B5D"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Este botón registra tu ubicación y genera una alerta de emergencia."
                               TextColor="Black"
                               HorizontalTextAlignment="Center"/>

                        <Label x:Name="UbicacionLabel"
                               Text="Ubicación: pendiente"
                               TextColor="#1D3148"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>

                        <Border x:Name="SOSActivoBox"
                                IsVisible="False"
                                BackgroundColor="#FFE5E5"
                                StrokeThickness="0"
                                Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="10">
                                <Label Text="🚨 Tienes una alerta SOS activa"
                                       FontAttributes="Bold"
                                       TextColor="#B00020"
                                       HorizontalTextAlignment="Center"/>

                                <Label x:Name="SOSActivoLabel"
                                       TextColor="Black"
                                       HorizontalTextAlignment="Center"/>

                                <Button Text="Finalizar mi alerta SOS"
                                        BackgroundColor="#82A914"
                                        TextColor="White"
                                        CornerRadius="25"
                                        Clicked="OnFinalizarSOSClicked"/>
                            </VerticalStackLayout>
                        </Border>

                        <Button Text="Enviar Alerta SOS"
                                BackgroundColor="#E64B5D"
                                TextColor="White"
                                CornerRadius="25"
                                HeightRequest="55"
                                Clicked="OnEnviarSOSClicked"/>

                        <Button Text="Llamar al 911"
                                BackgroundColor="#B00020"
                                TextColor="White"
                                CornerRadius="25"
                                HeightRequest="55"
                                Clicked="OnLlamarClicked"/>

                        <Button Text="Volver"
                                BackgroundColor="#82A914"
                                TextColor="White"
                                CornerRadius="25"
                                HeightRequest="50"
                                Clicked="OnVolverClicked"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>