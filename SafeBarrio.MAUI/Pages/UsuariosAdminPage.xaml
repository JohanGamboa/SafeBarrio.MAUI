<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeBarrio.MAUI.Pages.UsuariosAdminPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1F2F2F">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Image Source="logo_safebarrio.png"
               HeightRequest="90"
               HorizontalOptions="Center"/>

        <Label Text="Usuarios Registrados"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#1D3148"
               HorizontalTextAlignment="Center"/>

        <CollectionView x:Name="UsuariosCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#F0FFFFFF" Padding="15" Margin="0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding nombre}" FontSize="20" FontAttributes="Bold" TextColor="#1D3148"/>
                            <Label Text="{Binding correo}" TextColor="Black"/>
                            <Label Text="{Binding telefono}" TextColor="Black"/>
                            <Label Text="{Binding direccion}" TextColor="Black"/>
                            <Label Text="{Binding esAdmin, StringFormat='Admin: {0}'}" TextColor="#82A914" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Volver"
                BackgroundColor="#82A914"
                TextColor="White"
                CornerRadius="24"
                Clicked="OnVolverClicked"/>

    </VerticalStackLayout>
</ContentPage>